{
  "id": "api-test",
  "workflow_type": "api_test",
  "status": "pending",
  "input_schema": {
    "type": "object",
    "properties": {
      "api_base": { "type": "string", "description": "Base URL for the API" }
    },
    "required": ["api_base"]
  },
  "steps": [
    {
      "id": "list_agents",
      "label": "List available agents",
      "kind": { "type": "api_call", "method": "GET", "url": "{context.api_base}/agents" },
      "depends_on": [],
      "execution": "sequential",
      "requires": [{ "skill": "native:network" }]
    },
    {
      "id": "check_connections",
      "label": "Check workspace connections",
      "kind": { "type": "tool_call", "tool_name": "api_request", "input": { "method": "GET", "path": "/v1/connections" } },
      "depends_on": [],
      "execution": "parallel",
      "requires": [{ "skill": "native:network" }]
    },
    {
      "id": "summarize",
      "label": "Summarize workspace state",
      "kind": { "type": "checkpoint", "message": "Workspace scan complete." },
      "depends_on": ["list_agents", "check_connections"],
      "execution": "sequential"
    }
  ]
}
