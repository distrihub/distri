{
  "id": "scan-workspace",
  "workflow_type": "workspace_scan",
  "status": "pending",
  "input_schema": {
    "type": "object",
    "properties": {
      "api_base": { "type": "string", "description": "Base URL for the Distri API" }
    },
    "required": ["api_base"]
  },
  "steps": [
    {
      "id": "list_agents",
      "label": "List all agents",
      "kind": { "type": "api_call", "method": "GET", "url": "{context.api_base}/agents" },
      "depends_on": [],
      "execution": "parallel",
      "requires": [{ "skill": "native:network" }]
    },
    {
      "id": "list_skills",
      "label": "List all skills",
      "kind": { "type": "api_call", "method": "GET", "url": "{context.api_base}/skills" },
      "depends_on": [],
      "execution": "parallel",
      "requires": [{ "skill": "native:network" }]
    },
    {
      "id": "list_workflows",
      "label": "List workflows",
      "kind": { "type": "api_call", "method": "GET", "url": "{context.api_base}/workflows" },
      "depends_on": [],
      "execution": "parallel",
      "requires": [{ "skill": "native:network" }]
    },
    {
      "id": "done",
      "label": "Workspace scan complete",
      "kind": { "type": "checkpoint", "message": "Scanned agents, skills, and workflows." },
      "depends_on": ["list_agents", "list_skills", "list_workflows"],
      "execution": "sequential"
    }
  ]
}
