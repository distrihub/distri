# Copy to integration/.env and fill in. The runner sources this file.
# DO NOT commit the populated .env.

# --- Required for any test that talks to a server ---
DISTRI_API_KEY=dak_replace_me
DISTRI_BASE_URL=http://localhost:1341/v1
DISTRI_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --- Required for real-LLM tests (skipped silently if missing) ---
# At least one of these must be set:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: which backend to point at by default ---
# Values: cloud | opensource
DISTRI_BACKEND=opensource

# --- Optional: enable MockLLM on the server we boot ---
# 1 = default scenario, scenario:<name> = pick one, fixture:<path> = canned
DISTRI_MOCK_LLM=

# --- Optional: where to write logs ---
DISTRI_LOG=/tmp/distri-integration.log
